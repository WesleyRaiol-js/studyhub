generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  low
  medium
  high
}

enum AssignmentStatus {
  pending
  in_progress
  completed
  overdue
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  subjects    Subject[]
  assignments Assignment[]
  exams       Exam[]
  grades      Grade[]

  @@map("users")
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(150)
  code      String?  @db.VarChar(50)
  professor String?  @db.VarChar(120)
  semester  String   @db.VarChar(30)
  color     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignments Assignment[]
  exams       Exam[]
  grades      Grade[]

  @@unique([userId, name, semester], map: "subjects_user_id_name_semester_key")
  @@index([userId], map: "subjects_user_id_idx")
  @@index([userId, semester], map: "subjects_user_id_semester_idx")
  @@map("subjects")
}

model Assignment {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  subjectId   String           @map("subject_id") @db.Uuid
  title       String           @db.VarChar(180)
  description String?          @db.Text
  dueDate     DateTime         @map("due_date") @db.Timestamp(6)
  priority    Priority
  status      AssignmentStatus
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "assignments_user_id_idx")
  @@index([subjectId], map: "assignments_subject_id_idx")
  @@index([userId, status, dueDate], map: "assignments_user_id_status_due_date_idx")
  @@map("assignments")
}

model Exam {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  subjectId   String   @map("subject_id") @db.Uuid
  title       String   @db.VarChar(180)
  description String?  @db.Text
  examDate    DateTime @map("exam_date") @db.Timestamp(6)
  weight      Decimal? @db.Decimal(8, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "exams_user_id_idx")
  @@index([subjectId], map: "exams_subject_id_idx")
  @@index([userId, examDate], map: "exams_user_id_exam_date_idx")
  @@map("exams")
}

model Grade {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  title     String   @db.VarChar(180)
  score     Decimal  @db.Decimal(8, 2)
  maxScore  Decimal  @map("max_score") @db.Decimal(8, 2)
  weight    Decimal? @db.Decimal(8, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "grades_user_id_idx")
  @@index([subjectId], map: "grades_subject_id_idx")
  @@index([userId, subjectId], map: "grades_user_id_subject_id_idx")
  @@map("grades")
}
